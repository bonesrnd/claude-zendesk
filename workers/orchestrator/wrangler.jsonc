{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "resolve-orchestrator",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "secrets": {
    "required": ["BACKEND_AUTH_TOKEN", "TENANT_KEY", "WOO_BASE_URL"],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "resolve",
      "migrations_dir": "migrations",
    },
  ],
  "ratelimits": [
    {
      "name": "REQUEST_LIMITER",
      "namespace_id": "7182026",
      "simple": {
        "limit": 60,
        "period": 60,
      },
    },
  ],
  "triggers": {
    "crons": ["0 3 * * *"],
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
