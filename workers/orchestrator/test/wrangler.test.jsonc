{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "resolve-orchestrator-test",
  "main": "../src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "env": {
    "test": {
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "resolve-test",
          "database_id": "00000000-0000-0000-0000-000000000000",
          "migrations_dir": "../migrations",
        },
      ],
      "queues": {
        "producers": [
          {
            "binding": "KNOWLEDGE_INDEX_QUEUE",
            "queue": "resolve-knowledge-index-test",
          },
        ],
        "consumers": [
          {
            "queue": "resolve-knowledge-index-test",
            "max_batch_size": 1,
            "max_batch_timeout": 1,
            "max_retries": 2,
            "max_concurrency": 2,
            "retry_delay": 1,
          },
        ],
      },
      "ratelimits": [
        {
          "name": "REQUEST_LIMITER",
          "namespace_id": "9999999",
          "simple": {
            "limit": 60,
            "period": 60,
          },
        },
      ],
    },
  },
}
