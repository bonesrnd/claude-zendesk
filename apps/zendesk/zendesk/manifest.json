{
  "name": "Resolve",
  "author": {
    "name": "Bones R&D",
    "email": "bonesrnd@users.noreply.github.com"
  },
  "defaultLocale": "en",
  "private": true,
  "version": "1.1.0",
  "frameworkVersion": "2.0",
  "location": {
    "support": {
      "ticket_sidebar": {
        "url": "assets/index.html",
        "flexible": true
      }
    }
  },
  "domainWhitelist": ["{{setting.worker_host}}"],
  "parameters": [
    {
      "name": "worker_url",
      "type": "text",
      "required": true,
      "default": "https://resolve-orchestrator.bones-baa.workers.dev"
    },
    {
      "name": "worker_host",
      "type": "text",
      "required": true,
      "default": "resolve-orchestrator.bones-baa.workers.dev"
    },
    {
      "name": "zendesk_subdomain",
      "type": "text",
      "required": true,
      "default": "solutionpeptides"
    },
    {
      "name": "anthropic_model",
      "type": "text",
      "required": true,
      "default": "claude-sonnet-5"
    },
    {
      "name": "anthropic_effort",
      "type": "text",
      "required": true,
      "default": "medium"
    },
    {
      "name": "woo_solution_peptides_base_url",
      "type": "text",
      "required": true,
      "default": "https://solutionpeptides.net"
    },
    {
      "name": "woo_atomik_labz_base_url",
      "type": "text",
      "required": true,
      "default": "https://atomiklabz.com"
    },
    {
      "name": "shipstation_mode",
      "type": "text",
      "required": true,
      "default": "auto"
    },
    {
      "name": "backend_auth_token",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "anthropic_api_key",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "woo_solution_peptides_consumer_key",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "woo_solution_peptides_consumer_secret",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "woo_atomik_labz_consumer_key",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "woo_atomik_labz_consumer_secret",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "shipstation_v2_key",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "shipstation_v1_key",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    },
    {
      "name": "shipstation_v1_secret",
      "type": "text",
      "required": false,
      "secure": true,
      "scopes": ["header"]
    }
  ]
}
